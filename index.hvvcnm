<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Azx - Official Website</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, sans-serif;
      background: #f5f5f5;
      color: #222;
    }

    header {
      background: #222;
      color: white;
      padding: 20px;
      text-align: center;
    }

    header h1 {
      font-size: 40px;
      margin-bottom: 10px;
    }

    nav {
      margin-top: 15px;
    }

    nav a {
      color: white;
      text-decoration: none;
      margin: 0 10px;
      font-weight: bold;
    }

    .hero {
      background: #333;
      color: white;
      text-align: center;
      padding: 70px 20px;
    }

    .hero h2 {
      font-size: 36px;
      margin-bottom: 15px;
    }

    .hero p {
      font-size: 20px;
      margin-bottom: 25px;
    }

    .button {
      display: inline-block;
      background: white;
      color: #222;
      padding: 14px 25px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: bold;
    }

    section {
      padding: 50px 20px;
      max-width: 1100px;
      margin: auto;
    }

    section h2 {
      text-align: center;
      margin-bottom: 30px;
      font-size: 30px;
    }

    .products {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 25px;
    }

    .card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
    }

    .card-content {
      padding: 20px;
    }

    .card h3 {
      margin-bottom: 10px;
    }

    .card p {
      margin-bottom: 15px;
      color: #555;
    }

    .price {
      font-size: 20px;
      font-weight: bold;
      margin-bottom: 15px;
    }

    .order-button {
      display: inline-block;
      background: #222;
      color: white;
      padding: 10px 18px;
      border-radius: 6px;
      text-decoration: none;
    }

    .contact {
      background: white;
      border-radius: 12px;
      padding: 30px;
      max-width: 600px;
      margin: auto;
    }

    .contact input,
    .contact textarea {
      width: 100%;
      padding: 12px;
      margin-bottom: 15px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 16px;
    }

    .contact textarea {
      height: 120px;
    }

    .contact button {
      width: 100%;
      padding: 14px;
      background: #222;
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 16px;
    }

    footer {
      background: #222;
      color: white;
      text-align: center;
      padding: 30px;
      margin-top: 30px;
    }
  </style>
</head>

<body>

  <header>
    <h1>Azx</h1>
    <p>Official Website</p>

    <nav>
      <a href="#home">Home</a>
      <a href="#products">Products</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>


  <section class="hero" id="home">
    <h2>Welcome to Azx</h2>

    <p>
      Discover our products and services.
    </p>

    <a href="#products" class="button">
      View Products
    </a>
  </section>


  <section id="products">

    <h2>Our Products</h2>

    <div class="products">

      <div class="card">

        <img src="https://via.placeholder.com/500x400" alt="Product 1">

        <div class="card-content">

          <h3>Product One</h3>

          <p>
            Add a description of your product here.
          </p>

          <div class="price">
            $20
          </div>

          <a href="#contact" class="order-button">
            Order Now
          </a>

        </div>
      </div>


      <div class="card">

        <img src="https://via.placeholder.com/500x400" alt="Product 2">

        <div class="card-content">

          <h3>Product Two</h3>

          <p>
            Add a description of your product here.
          </p>

          <div class="price">
            $30
          </div>

          <a href="#contact" class="order-button">
            Order Now
          </a>

        </div>
      </div>


      <div class="card">

        <img src="https://via.placeholder.com/500x400" alt="Product 3">

        <div class="card-content">

          <h3>Product Three</h3>

          <p>
            Add a description of your product here.
          </p>

          <div class="price">
            $40
          </div>

          <a href="#contact" class="order-button">
            Order Now
          </a>

        </div>
      </div>

    </div>

  </section>


  <section id="contact">

    <h2>Contact & Order</h2>

    <div class="contact">

      <p style="margin-bottom: 20px;">
        Interested in a product? Send us a message!
      </p>

      <form action="https://formsubmit.co/YOUR-EMAIL-HERE" method="POST">

        <input
          type="text"
          name="name"
          placeholder="Your Name"
          required
        >

        <input
          type="email"
          name="email"
          placeholder="Your Email"
          required
        >

        <textarea
          name="message"
          placeholder="What would you like to order?"
          required
        ></textarea>

        <button type="submit">
          Send Order
        </button>

      </form>

    </div>

  </section>


  <footer>
    <p>© 2026 Azx. All rights reserved.</p>
  </footer>

</body>
</html>
<div class="product-card">
  <img src="product1.jpg" alt="My product">
  <h2>My Product</h2>
  <p>€20</p>
  <button>Order Now</button>
</div>
